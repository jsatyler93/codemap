{
  "name": "codemap",
  "displayName": "CodeMap",
  "description": "Python-first interactive flowcharts, call graphs, and workspace visualization for VS Code.",
  "version": "0.1.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Visualization",
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onLanguage:python",
    "onDebug"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "codemap",
          "title": "CodeMap",
          "icon": "resources/codemap-icon.svg"
        }
      ]
    },
    "views": {
      "codemap": [
        {
          "id": "codemap.files",
          "name": "Scope",
          "icon": "resources/codemap-icon.svg"
        },
        {
          "type": "webview",
          "id": "codemap.actions",
          "name": "Controls",
          "icon": "resources/codemap-icon.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "codemap.showFlowchart",
        "title": "CodeMap: Show Python Flowchart for Current Function",
        "category": "CodeMap"
      },
      {
        "command": "codemap.showFileGraph",
        "title": "CodeMap: Call Graph for File",
        "category": "CodeMap"
      },
      {
        "command": "codemap.showWorkspaceGraph",
        "title": "CodeMap: Workspace Call Graph",
        "category": "CodeMap"
      },
      {
        "command": "codemap.refresh",
        "title": "CodeMap: Refresh Analysis",
        "category": "CodeMap"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "resourceLangId == python",
          "command": "codemap.showFlowchart",
          "group": "codemap@1"
        },
        {
          "when": "resourceLangId == python",
          "command": "codemap.showFileGraph",
          "group": "codemap@2"
        }
      ],
      "editor/title/context": [
        {
          "when": "resourceLangId == python",
          "command": "codemap.showFileGraph",
          "group": "navigation@2"
        }
      ],
      "explorer/context": [
        {
          "when": "resourceLangId == python",
          "command": "codemap.showFileGraph",
          "group": "navigation@2"
        }
      ]
    },
    "configuration": {
      "type": "object",
      "title": "CodeMap",
      "properties": {
        "codemap.pythonPath": {
          "type": "string",
          "default": "",
          "description": "Path to a Python 3 interpreter used to run the static analyzer. If blank, uses 'python' on PATH."
        },
        "codemap.workspace.maxFiles": {
          "type": "number",
          "default": 400,
          "description": "Cap on number of Python files to index in workspace graph."
        },
        "codemap.useJedi": {
          "type": "boolean",
          "default": true,
          "description": "If true and the 'jedi' package is installed in the analyzer's interpreter, use it to upgrade unresolved call sites with type-aware resolution."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "npm run compile:ext && npm run bundle:webview",
    "compile:ext": "tsc -p ./",
    "bundle:webview": "esbuild webview/main.js --bundle --format=iife --target=es2020 --outfile=dist/webview/main.js",
    "watch": "tsc -watch -p ./",
    "watch:webview": "esbuild webview/main.js --bundle --format=iife --target=es2020 --outfile=dist/webview/main.js --watch"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.4.0"
  }
}
